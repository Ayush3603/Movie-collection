<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Movie Collection</title>
  <link rel="stylesheet" href="/css/movies.css">
</head>
<body>
  <div class="container">
    <header class="header">
      <h1>🎬 Movie Collection</h1>
      <div class="filters">
        <a href="/" class="filter-btn <%= filter === 'all' ? 'active' : '' %>">All</a>
        <a href="/?filter=watched" class="filter-btn <%= filter === 'watched' ? 'active' : '' %>">Watched</a>
        <a href="/?filter=watchlist" class="filter-btn <%= filter === 'watchlist' ? 'active' : '' %>">Watchlist</a>
      </div>
      <a href="/add" class="add-btn">+ Add Movie</a>
    </header>

    <div class="movies-grid">
      <% movies.forEach(movie => { %>
        <div class="movie-card <%= movie.watched ? 'watched' : '' %>">
          <div class="movie-poster">
            <span class="year-badge"><%= movie.year %></span>
            <span class="genre-tag"><%= movie.genre %></span>
          </div>
          <div class="movie-details">
            <h3 class="movie-title"><%= movie.title %></h3>
            <p class="movie-director">Directed by <%= movie.director %></p>
            
            <% if (movie.rating > 0) { %>
              <div class="movie-rating">
                <span class="stars">
                  <% for(let i=0; i<10; i++) { %>
                    <%= i < movie.rating ? '★' : '☆' %>
                  <% } %>
                </span>
              </div>
            <% } %>
            
            <% if (movie.review) { %>
              <p class="movie-review">"<%= movie.review %>"</p>
            <% } %>
            
            <div class="movie-actions">
              <a href="/toggle/<%= movie.id %>" class="action-btn toggle">
                <%= movie.watched ? '↩️ Unwatch' : '✓ Watched' %>
              </a>
              <a href="/delete/<%= movie.id %>" class="action-btn delete">🗑️ Delete</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
